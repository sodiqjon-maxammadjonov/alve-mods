# Bot tokeni (BotFather dan olinadi)
BOT_TOKEN=1234567890:AAF...

# Supabase yoki boshqa PostgreSQL ulanish stringi
# Supabase: Settings → Database → Connection string → URI
DB_LINK=postgresql://postgres:[YOUR-PASSWORD]@db.xxxx.supabase.co:5432/postgres

# Admin Telegram ID lari (vergul bilan ajratiladi)
ADMIN_IDS=123456789,987654321

# Admin username (@ siz)
ADMIN_USERNAME=admin_username

# Maxfiy guruh ID (ixtiyoriy — fayl saqlash uchun)
SECRET_GROUP_ID=-1001234567890
